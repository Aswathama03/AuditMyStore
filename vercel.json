{
  "version": 2,
  "builds": [
    { "src": "api/auth.js",      "use": "@vercel/node" },
    { "src": "api/callback.js",  "use": "@vercel/node" },
    { "src": "api/chat.js",      "use": "@vercel/node" },
    { "src": "api/checkout.js",  "use": "@vercel/node" },
    { "src": "api/webhook.js",   "use": "@vercel/node" },
    { "src": "api/verify.js",    "use": "@vercel/node" },
    { "src": "api/account.js",   "use": "@vercel/node" },
    { "src": "api/register.js",  "use": "@vercel/node" },
    { "src": "api/login.js",     "use": "@vercel/node" },
    { "src": "index.html",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth",      "dest": "/api/auth.js"      },
    { "src": "/api/callback",  "dest": "/api/callback.js"  },
    { "src": "/api/chat",      "dest": "/api/chat.js"      },
    { "src": "/api/checkout",  "dest": "/api/checkout.js"  },
    { "src": "/api/webhook",   "dest": "/api/webhook.js"   },
    { "src": "/api/verify",    "dest": "/api/verify.js"    },
    { "src": "/api/account",   "dest": "/api/account.js"   },
    { "src": "/api/register",  "dest": "/api/register.js"  },
    { "src": "/api/login",     "dest": "/api/login.js"     },
    { "src": "/",              "dest": "/index.html"       }
  ]
}
